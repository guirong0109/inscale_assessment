# Streamlit Cloud Secrets — paste this into your app's Settings → Secrets panel.
# Do NOT commit secrets.toml to version control.
#
# To get the password_hash values:
#   1. Run:  python setup_credentials.py
#   2. Open the generated credentials.yaml
#   3. Copy the password_hash values for each user into this file

# DeepSeek API key
DEEPSEEK_API_KEY = "your-deepseek-api-key-here"

# User credentials (bcrypt hashes — generate with setup_credentials.py)
[users.admin]
name          = "Administrator"
role          = "admin"
password_hash = "paste-bcrypt-hash-here"

[users.user]
name          = "Regular User"
role          = "user"
password_hash = "paste-bcrypt-hash-here"
